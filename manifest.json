{
  "name": "gff-viewer",
  "version": "1.1.3",
  "description": "Interactive GFF/GTF annotation viewer with feature type coloring, attribute parsing, and region statistics",
  "extensions": [
    "gff",
    "gtf",
    "gff3"
  ],
  "entry": "index.js",
  "style": "style.css",
  "data_source": {
    "type": "text",
    "row_count": "grep -cv '^#' '{file}'",
    "metadata": "grep '^#' '{file}'",
    "rows": "grep -v '^#' '{file}' | sed -n '{start},{end}p'",
    "col_headers": ["seqid", "source", "type", "start", "end", "score", "strand", "phase", "attributes"],
    "meta_parse": "none",
    "allow_nonzero_exit": false,
    "fallback": [
      {
        "type": "docker",
        "image": "ubuntu:22.04",
        "row_count": "grep -cv '^#' '{file}'",
        "metadata": "grep '^#' '{file}'",
        "rows": "grep -v '^#' '{file}' | sed -n '{start},{end}p'",
        "col_headers": ["seqid", "source", "type", "start", "end", "score", "strand", "phase", "attributes"],
        "meta_parse": "none",
        "allow_nonzero_exit": false
      }
    ]
  }
}
